# Shell scripts must keep LF line endings; CRLF breaks #!/bin/sh shebangs in Linux containers.
*.sh text eol=lf

# Python and config files — consistent LF everywhere.
*.py text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.css text eol=lf
