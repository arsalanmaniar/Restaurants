DEBUG=false

# Neon PostgreSQL — copy from Neon console > Connection Details > Connection string
DATABASE_URL=postgresql+psycopg://user:password@host/dbname?sslmode=require

# Upstash Redis (optional for Phase 0 — only needed if caching/queues are active)
REDIS_URL=redis://localhost:6379/0

# Groq — https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# UltraMsg — https://ultramsg.com/instances
ULTRAMSG_INSTANCE_ID=
ULTRAMSG_TOKEN=
# Random secret appended to the webhook URL: /webhooks/ultramsg?secret=<this value>
ULTRAMSG_WEBHOOK_SECRET=

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production

# Public base URL of THIS backend (used in payment callback links).
# For HF Spaces: https://<your-username>-<space-name>.hf.space
PUBLIC_BASE_URL=http://localhost:8020

# Comma-separated list of production frontend origins (Vercel URLs).
# Example: https://abhiaya.vercel.app,https://abhiaya-admin.vercel.app
# Leave blank in local dev — the localhost regex handles it when DEBUG=true.
CORS_ALLOWED_ORIGINS=

# Payment providers (not required for Phase 0 demo)
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_POST_URL=https://sandbox.jazzcash.com.pk/CustomerPortal/transactionmanagement/merchantform

EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
EASYPAISA_POST_URL=https://easypaystg.easypaisa.com.pk/easypay/Index.jsf
